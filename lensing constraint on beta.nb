   RowBox[{
    RowBox[{"pc", "=", 
     RowBox[{"3.0857", "*", 
      RowBox[{"10", "^", "16"}]}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Sgr", " ", "A", "*", "Parameters"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"MBH", "=", 
     RowBox[{"4.154", "*", 
      RowBox[{"10", "^", "6"}], "*", "Msun"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Distance", "=", 
     RowBox[{"8178", "*", "pc"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"RsPhys", "=", 
     RowBox[{"2", "*", "G", "*", 
      RowBox[{"MBH", "/", 
       RowBox[{"c", "^", "2"}]}]}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"EHT", " ", "OBSERVATION"}], "*)"}], "\[IndentingNewLine]", 
