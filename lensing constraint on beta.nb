   RowBox[{
    RowBox[{"boundUpper", "=", 
     RowBox[{"thetaObs", "+", 
      RowBox[{"2", "*", "thetaErr"}]}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
