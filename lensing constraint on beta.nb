      RowBox[{"data", ",", 
       RowBox[{"{", 
        RowBox[{"_", ",", 
         RowBox[{"Missing", "[", "]"}]}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
