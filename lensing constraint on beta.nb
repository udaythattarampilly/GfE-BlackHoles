   RowBox[{
    RowBox[{
     RowBox[{"Afun", "[", 
      RowBox[{"r_", ",", "b_"}], "]"}], ":=", 
     RowBox[{"1.0", "-", 
      RowBox[{"1.0", "/", "r"}], "-", 
      RowBox[{"b", "/", 
       RowBox[{"(", 
        RowBox[{"48.0", "*", 
         RowBox[{"r", "^", "4"}]}], ")"}]}]}]}], ";"}], "\[IndentingNewLine]",
    "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"CalculateShadow", "[", 
      RowBox[{"beta_", "?", "NumericQ"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "rps", ",", "Aval", ",", "bCrit", ",", "thetaRad", ",", 
         "thetaMicro"}], "}"}], ",", 
       RowBox[{"(*", 
        RowBox[{"Find", " ", "Photon", " ", "Sphere"}], "*)"}], 
       RowBox[{"(*", 
        RowBox[{
        "Using", " ", "Quiet", " ", "to", " ", "suppress", " ", "messages", 
         " ", "if", " ", "beta", " ", "creates", " ", "no", " ", "root"}], 
        "*)"}], 
       RowBox[{
        RowBox[{"rps", "=", 
         RowBox[{"Quiet", "[", 
          RowBox[{"r", "/.", " ", 
           RowBox[{"FindRoot", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"16", "*", 
                RowBox[{"r", "^", "4"}]}], "-", 
               RowBox[{"24", "*", 
                RowBox[{"r", "^", "3"}]}], "-", "beta"}], "==", "0"}], ",", 
             RowBox[{"{", 
              RowBox[{"r", ",", "1.5"}], "}"}], ",", 
             RowBox[{"Method", "->", "\"\<Newton\>\""}]}], "]"}]}], "]"}]}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"!", 
            RowBox[{"NumericQ", "[", "rps", "]"}]}], "||", 
           RowBox[{"rps", "<=", "1.01"}]}], ",", 
          RowBox[{"Return", "[", 
           RowBox[{"Missing", "[", "]"}], "]"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Aval", "=", 
         RowBox[{"Afun", "[", 
          RowBox[{"rps", ",", "beta"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"Aval", "<=", "0"}], ",", 
          RowBox[{"Return", "[", 
           RowBox[{"Missing", "[", "]"}], "]"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"bCrit", "=", 
         RowBox[{"rps", "/", 
          RowBox[{"Sqrt", "[", "Aval", "]"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"thetaRad", "=", 
         RowBox[{"2", "*", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"bCrit", "*", "RsPhys"}], ")"}], "/", "Distance"}]}]}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"thetaMicro", "=", 
         RowBox[{"thetaRad", "*", 
          RowBox[{"(", 
           RowBox[{"180.0", "/", "Pi"}], ")"}], "*", "3600.0", "*", 
          RowBox[{"10", "^", "6"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Return", "[", "thetaMicro", "]"}], ";"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", " ", 
