        RowBox[{"g", "[", "R", "]"}], "==", 
        RowBox[{"initG", "[", "R", "]"}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"f", "'"}], "[", "R", "]"}], "==", 
