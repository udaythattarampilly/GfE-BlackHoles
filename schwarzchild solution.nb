Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Example", " ", "numerical", " ", "integration", " ", "skeleton", " ", 
    "once", " ", "coefficients", " ", "are", " ", "known"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{"initF", ",", "initG"}], "]"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"initF", "[", "r_", "]"}], "=", 
     RowBox[{
      RowBox[{"Evaluate", "[", 
       RowBox[{"f", "[", "r", "]"}], "]"}], "/.", 
      RowBox[{"solNum1", "[", 
       RowBox[{"[", "1", "]"}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"initG", "[", "r_", "]"}], "=", 
     RowBox[{
      RowBox[{"Evaluate", "[", 
       RowBox[{"g", "[", "r", "]"}], "]"}], "/.", 
      RowBox[{"solNum1", "[", 
       RowBox[{"[", "1", "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"ClearAll", "[", 
    RowBox[{"f", ",", "g", ",", "G", ",", "k", ",", "R", ",", "solNum"}], 
    "]"}], "\n", 
   RowBox[{
    RowBox[{"R", "=", "10"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"G", "=", "1"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"ics", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"f", "[", "R", "]"}], "==", 
        RowBox[{"initF", "[", "R", "]"}]}], ",", 
       RowBox[{
        RowBox[{"g", "[", "R", "]"}], "==", 
        RowBox[{"initG", "[", "R", "]"}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"f", "'"}], "[", "R", "]"}], "==", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"initF", "[", "r", "]"}], ",", "r"}], "]"}]}], "/.", " ", 
        RowBox[{"r", "->", "R"}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"g", "'"}], "[", "R", "]"}], "==", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"initG", "[", "r", "]"}], ",", "r"}], "]"}]}], "/.", " ", 
        RowBox[{"r", "->", "R"}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"f", "''"}], "[", "R", "]"}], "==", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"initF", "[", "r", "]"}], ",", "r", ",", "r"}], "]"}]}], "/.",
         " ", 
        RowBox[{"r", "->", "R"}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"g", "''"}], "[", "R", "]"}], "==", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"initG", "[", "r", "]"}], ",", "r", ",", "r"}], "]"}]}], "/.",
         " ", 
        RowBox[{"r", "->", "R"}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{
    RowBox[{"solNum", "=", 
     RowBox[{"NDSolve", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"eom1", "[", 
           RowBox[{"r", ",", "G"}], "]"}], "==", "0"}], ",", 
         RowBox[{
          RowBox[{"eom4", "[", 
           RowBox[{"r", ",", "G"}], "]"}], "==", "0"}], ",", "ics"}], "}"}], 
       ",", 
       RowBox[{"{", 
        RowBox[{"f", ",", "g"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"r", ",", "1", ",", "R"}], "}"}], ",", 
       RowBox[{"Method", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<IndexReduction\>\"", "->", "Automatic"}], "}"}]}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"Evaluate", "[", 
         RowBox[{"g", "[", "r", "]"}], "]"}], "/.", "solNum"}], ",", 
       RowBox[{
        RowBox[{"Evaluate", "[", 
         RowBox[{"f", "[", "r", "]"}], "]"}], "/.", "solNum"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "2", ",", "10"}], "}"}], ",", 
     RowBox[{"PlotRange", "->", "Full"}]}], "]"}]}]}]], "Input",
