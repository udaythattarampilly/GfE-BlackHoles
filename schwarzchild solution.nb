Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Example", " ", "numerical", " ", "integration", " ", "skeleton", " ", 
    "once", " ", "coefficients", " ", "are", " ", "known"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{
    "f", ",", "g", ",", "F", ",", "G", ",", "k", ",", "R", ",", "r0", ",", 
     "solNum"}], "]"}], "\n", 
   RowBox[{
    RowBox[{"R", "=", "5000"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"r0", "=", "1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"G", "=", "1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"initF", "[", "r_", "]"}], "=", 
     RowBox[{"1", "-", 
      RowBox[{"1", "/", "r"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"initG", "[", "r_", "]"}], "=", 
     RowBox[{"1", "/", 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{"1", "/", "r"}]}], ")"}]}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ics", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"f", "[", "R", "]"}], "==", 
        RowBox[{"initF", "[", "R", "]"}]}], ",", 
       RowBox[{
        RowBox[{"g", "[", "R", "]"}], "==", 
        RowBox[{"initG", "[", "R", "]"}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"f", "'"}], "[", "R", "]"}], "==", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"initF", "[", "r", "]"}], ",", "r"}], "]"}]}], "/.", " ", 
        RowBox[{"r", "->", "R"}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"g", "'"}], "[", "R", "]"}], "==", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"initG", "[", "r", "]"}], ",", "r"}], "]"}]}], "/.", " ", 
        RowBox[{"r", "->", "R"}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"f", "''"}], "[", "R", "]"}], "==", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"initF", "[", "r", "]"}], ",", "r", ",", "r"}], "]"}]}], "/.",
         " ", 
        RowBox[{"r", "->", "R"}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"g", "''"}], "[", "R", "]"}], "==", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"initG", "[", "r", "]"}], ",", "r", ",", "r"}], "]"}]}], "/.",
         " ", 
        RowBox[{"r", "->", "R"}]}]}], "}"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"solNum", "=", 
     RowBox[{"NDSolve", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"eom1", "[", 
           RowBox[{"r", ",", "G"}], "]"}], "==", "0"}], ",", 
         RowBox[{
          RowBox[{"eom2", "[", 
           RowBox[{"r", ",", "G"}], "]"}], "==", "0"}], ",", "ics"}], "}"}], 
       ",", 
       RowBox[{"{", 
        RowBox[{"f", ",", "g"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"r", ",", "r0", ",", "R"}], "}"}], ",", 
       RowBox[{"Method", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<IndexReduction\>\"", "->", "Automatic"}], "}"}]}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"Evaluate", "[", 
         RowBox[{"g", "[", "r", "]"}], "]"}], "/.", "solNum"}], ",", 
       RowBox[{
        RowBox[{"Evaluate", "[", 
         RowBox[{"f", "[", "r", "]"}], "]"}], "/.", "solNum"}], ",", 
       RowBox[{
        RowBox[{"1", "/", 
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{"1", "/", "r"}]}], ")"}]}], "+", 
        FractionBox["G", 
         RowBox[{"12", " ", 
          SuperscriptBox["r", "4"]}]]}], ",", 
       RowBox[{"1", "-", 
        RowBox[{"1", "/", "r"}], "-", 
        RowBox[{"G", "/", 
         RowBox[{"(", 
          RowBox[{"48", " ", 
           SuperscriptBox["r", "4"]}], ")"}]}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "2", ",", "20"}], "}"}], ",", 
     RowBox[{"PlotRange", "->", "Full"}], ",", 
     RowBox[{"PlotTheme", "->", "\"\<Scientific\>\""}], ",", 
     RowBox[{"FrameLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
       "\"\<\!\(\*FractionBox[\(r\), SubscriptBox[\(r\), \(S\)]]\)\>\"", ",", 
        "\"\<metric component\>\""}], "}"}]}], ",", 
     RowBox[{
     "PlotLabel", "->", 
      "\"\<A(r) and B(r) as a function of r (measured in units of \
\!\(\*SubscriptBox[\(r\), \(S\)]\))\>\""}], ",", 
     RowBox[{"PlotStyle", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", "Thick", "}"}], ",", 
        RowBox[{"(*", "solid", "*)"}], 
        RowBox[{"{", "Thick", "}"}], ",", 
        RowBox[{"(*", "solid", "*)"}], 
        RowBox[{"{", 
         RowBox[{"Dashed", ",", "Thick"}], "}"}], ",", 
        RowBox[{"(*", "dashed", "*)"}], 
        RowBox[{"{", 
         RowBox[{"Dashed", ",", "Thick"}], "}"}]}], "        ", 
       RowBox[{"(*", "dashed", "*)"}], "}"}]}], ",", 
     RowBox[{"PlotLegends", "->", 
      RowBox[{"Placed", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
         "\"\<A(r)\>\"", ",", "\"\<B(r)\>\"", ",", 
          "\"\<1/(1-\!\(\*SubscriptBox[\(r\), \
\(S\)]\)/r)+\!\(\*FractionBox[\(\[Beta]\\\ \\\ \*SuperscriptBox[SubscriptBox[\
\(r\), \(S\)], \(2\)]\), \(12\\\ \*SuperscriptBox[\(r\), \(4\)]\)]\)\>\"", 
          ",", "\"\<1-rs/r-\[Beta] \!\(\*SuperscriptBox[SubscriptBox[\(r\), \
\(S\)], \(2\)]\)/(48 \!\(\*SuperscriptBox[\(r\), \(4\)]\))\>\""}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0.5", ",", "0.7"}], "}"}]}], "]"}]}]}], "]"}]}]}]], "Input",
