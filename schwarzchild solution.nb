          RowBox[{
           RowBox[{"initF", "[", "r", "]"}], ",", "r", ",", "r"}], "]"}]}], "/.",
         " ", 
        RowBox[{"r", "->", "R"}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"g", "''"}], "[", "R", "]"}], "==", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"initG", "[", "r", "]"}], ",", "r", ",", "r"}], "]"}]}], "/.",
         " ", 
        RowBox[{"r", "->", "R"}]}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{
    RowBox[{"solNum1", "=", 
     RowBox[{"NDSolve", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{
