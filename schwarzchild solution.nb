      RowBox[{"{", 
       RowBox[{
       "\"\<A(r)\>\"", ",", "\"\<B(r)\>\"", ",", 
        "\"\<1/(1-\!\(\*SubscriptBox[\(r\), \(S\)]\)/r)+\!\(\*FractionBox[\(\
\[Beta]\\\ \\\ \*SuperscriptBox[SubscriptBox[\(r\), \(S\)], \(2\)]\), \(12\\\ \
\*SuperscriptBox[\(r\), \(4\)]\)]\)\>\"", ",", 
        "\"\<1-rs/r-\[Beta] \!\(\*SuperscriptBox[SubscriptBox[\(r\), \(S\)], \
\(2\)]\)/(48 \!\(\*SuperscriptBox[\(r\), \(4\)]\))\>\""}], "}"}], ",", 
