Cell[BoxData[
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"Evaluate", "[", 
       RowBox[{"g", "[", "r", "]"}], "]"}], "/.", "solNum1"}], ",", 
     RowBox[{
      RowBox[{"Evaluate", "[", 
       RowBox[{"f", "[", "r", "]"}], "]"}], "/.", "solNum1"}], ",", 
     RowBox[{
      RowBox[{"1", "/", 
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"1", "/", "r"}]}], ")"}]}], "+", 
      FractionBox["G", 
       RowBox[{"12", " ", 
        SuperscriptBox["r", "4"]}]]}], ",", 
     RowBox[{"1", "-", 
      RowBox[{"1", "/", "r"}], "-", 
      RowBox[{"G", "/", 
       RowBox[{"(", 
        RowBox[{"48", " ", 
         SuperscriptBox["r", "4"]}], ")"}]}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"r", ",", "5", ",", "20"}], "}"}], ",", 
   RowBox[{"PlotRange", "->", "Full"}], ",", 
   RowBox[{"PlotTheme", "->", "\"\<Scientific\>\""}], ",", 
   RowBox[{"FrameLabel", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
     "\"\<\!\(\*FractionBox[\(r\), SubscriptBox[\(r\), \(S\)]]\)\>\"", ",", 
      "\"\<metric component\>\""}], "}"}]}], ",", 
   RowBox[{
   "PlotLabel", "->", 
    "\"\<A(r) and B(r) as a function of r (measured in units of \
\!\(\*SubscriptBox[\(r\), \(S\)]\))\>\""}], ",", 
   RowBox[{"PlotStyle", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", "Thick", "}"}], ",", 
      RowBox[{"(*", "solid", "*)"}], 
      RowBox[{"{", "Thick", "}"}], ",", 
      RowBox[{"(*", "solid", "*)"}], 
      RowBox[{"{", 
       RowBox[{"Dashed", ",", "Thick"}], "}"}], ",", 
      RowBox[{"(*", "dashed", "*)"}], 
      RowBox[{"{", 
       RowBox[{"Dashed", ",", "Thick"}], "}"}]}], "        ", 
     RowBox[{"(*", "dashed", "*)"}], "}"}]}], ",", 
