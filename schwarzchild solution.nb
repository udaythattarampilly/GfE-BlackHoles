     RowBox[{
      RowBox[{"Evaluate", "[", 
       RowBox[{"g", "[", "r", "]"}], "]"}], "/.", "solNum"}], ",", 
     RowBox[{
      RowBox[{"Evaluate", "[", 
       RowBox[{"f", "[", "r", "]"}], "]"}], "/.", "solNum"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"r", ",", "20", ",", "1000"}], "}"}], ",", 
   RowBox[{"PlotRange", "->", "Full"}]}], 
  "]"}], "\[IndentingNewLine]"}], "Input",
