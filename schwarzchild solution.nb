Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"ClearAll", "[", 
  RowBox[{"g1", ",", "g3", ",", "g2", ",", "eoma"}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"g1", "[", "r_", "]"}], ":=", 
   FractionBox[
    RowBox[{
     RowBox[{"g", "[", "r", "]"}], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"2", " ", 
        RowBox[{"f", "[", "r", "]"}], " ", 
        RowBox[{
         SuperscriptBox["f", "\[Prime]",
          MultilineFunction->None], "[", "r", "]"}]}], "-", 
       RowBox[{"r", " ", 
        SuperscriptBox[
         RowBox[{
          SuperscriptBox["f", "\[Prime]",
           MultilineFunction->None], "[", "r", "]"}], "2"]}], "+", 
       RowBox[{"2", " ", "r", " ", 
        RowBox[{"f", "[", "r", "]"}], " ", 
        RowBox[{
         SuperscriptBox["f", "\[Prime]\[Prime]",
          MultilineFunction->None], "[", "r", "]"}]}]}], ")"}]}], 
    RowBox[{
     RowBox[{"f", "[", "r", "]"}], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"2", " ", 
        RowBox[{"f", "[", "r", "]"}]}], "+", 
       RowBox[{"r", " ", 
        RowBox[{
         SuperscriptBox["f", "\[Prime]",
          MultilineFunction->None], "[", "r", "]"}]}]}], ")"}]}]]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"g2", "[", "r_", "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{"D", "[", 
      RowBox[{
       RowBox[{"g1", "[", "z", "]"}], ",", "z"}], "]"}], "/.", 
     RowBox[{"z", "->", "r"}]}], "//", "Simplify"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"g3", "[", "r_", "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{"D", "[", 
      RowBox[{
       RowBox[{"g2", "[", "z", "]"}], ",", "z"}], "]"}], "/.", 
     RowBox[{"z", "->", "r"}]}], "//", "Simplify"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"eoma", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"eom4", "[", 
         RowBox[{"r", ",", "G"}], "]"}], "/.", " ", 
        RowBox[{
         RowBox[{
          SuperscriptBox["g", 
           TagBox[
            RowBox[{"(", "3", ")"}],
            Derivative],
           MultilineFunction->None], "[", "r", "]"}], "->", 
         RowBox[{"g3", "[", "r", "]"}]}]}], "/.", 
       RowBox[{
        RowBox[{
         RowBox[{"g", "''"}], "[", "r", "]"}], "->", 
        RowBox[{"g2", "[", "r", "]"}]}]}], "/.", 
      RowBox[{
       RowBox[{
        RowBox[{"g", "'"}], "[", "r", "]"}], "->", 
       RowBox[{"g1", "[", "r", "]"}]}]}], "//", "Simplify"}]}], ";"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "Numerical", " ", "evaluation", " ", "of", " ", "the", " ", "two", " ", 
    "reduced", " ", "equations"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"ClearAll", "[", 
  RowBox[{
  "f", ",", "g", ",", "F", ",", "G", ",", "k", ",", "R", ",", "r0", ",", 
   "solNum", ",", "initF", ",", "initG"}], "]"}], "\n", 
 RowBox[{
  RowBox[{"R", "=", "1000"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"r0", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"G", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"initF", "[", "r_", "]"}], "=", 
   RowBox[{"1", "-", 
    RowBox[{"(", 
     RowBox[{"1", "/", "r"}], ")"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"initG", "[", "r_", "]"}], "=", 
    RowBox[{"1", "/", 
     RowBox[{"(", 
      RowBox[{"1", "-", 
       RowBox[{"(", 
        RowBox[{"1", "/", "r"}], ")"}]}], ")"}]}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ics", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"f", "[", "R", "]"}], "==", 
       RowBox[{"initF", "[", "R", "]"}]}], ",", 
      RowBox[{
       RowBox[{"g", "[", "R", "]"}], "==", 
       RowBox[{"initG", "[", "R", "]"}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"f", "'"}], "[", "R", "]"}], "==", 
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"initF", "[", "r", "]"}], ",", "r"}], "]"}]}], "/.", " ", 
       RowBox[{"r", "->", "R"}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"g", "'"}], "[", "R", "]"}], "==", 
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"initG", "[", "r", "]"}], ",", "r"}], "]"}]}], "/.", " ", 
       RowBox[{"r", "->", "R"}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"f", "''"}], "[", "R", "]"}], "==", 
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"initF", "[", "r", "]"}], ",", "r", ",", "r"}], "]"}]}], "/.", 
       RowBox[{"r", "->", "R"}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"g", "''"}], "[", "R", "]"}], "==", 
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"initG", "[", "r", "]"}], ",", "r", ",", "r"}], "]"}]}], "/.",
        " ", 
       RowBox[{"r", "->", "R"}]}]}], "}"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"solNum", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"eoma", "==", "0"}], ",", 
       RowBox[{
        RowBox[{"eom1", "[", 
         RowBox[{"r", ",", "G"}], "]"}], "==", "0"}], ",", "ics"}], "}"}], 
     ",", 
     RowBox[{"{", 
      RowBox[{"f", ",", "g"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "r0", ",", "R"}], "}"}], ",", 
     RowBox[{"Method", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<IndexReduction\>\"", "->", "Automatic"}], "}"}]}]}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
